# ─── REQUIRED ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# Your bot's Application ID — Dev Portal → your app → General Information → Application ID
# Required for slash command registration
CLIENT_ID=your_application_id_here

# Your Discord user ID — grants Owner-level commands (auth, persona switching)
OWNER_ID=your_discord_user_id_here

# ─── CHAT PROVIDER (pick one, set its key below) ─────────────────────────────
# Options: gemini | groq | openai | anthropic | mistral | cohere | ollama
AI_PROVIDER=groq

# Leave blank to use the provider's default model.
# Use /provider models in Discord to see options, /provider set to switch live.
AI_MODEL=

GEMINI_API_KEY=        # https://aistudio.google.com/app/apikey — free tier
GROQ_API_KEY=          # https://console.groq.com/keys — free
OPENAI_API_KEY=        # https://platform.openai.com/api-keys — paid
ANTHROPIC_API_KEY=     # https://console.anthropic.com/settings/keys — paid
MISTRAL_API_KEY=       # https://console.mistral.ai/api-keys/ — free tier
COHERE_API_KEY=        # https://dashboard.cohere.com/api-keys — free tier

# Ollama only (self-hosted / local model server)
OLLAMA_BASE_URL=http://localhost:11434

# ─── IMAGE PROVIDER (separate from chat) ─────────────────────────────────────
# Options: gemini | together | openai-dall-e | stability | none
# "gemini" uses Gemini's native image generation (Nano Banana) — reuses GEMINI_API_KEY.
# "none" disables /imagine entirely.
IMAGE_PROVIDER=together

# Leave blank to use the provider's default model.
IMAGE_MODEL=

TOGETHER_API_KEY=      # https://api.together.ai/settings/api-keys — free tier
STABILITY_API_KEY=     # https://platform.stability.ai/account/credits — paid

# ─── PERSONA ─────────────────────────────────────────────────────────────────
# Starting ACTIVE persona ID (used for fresh @mentions/DMs until changed with
# /persona set). One of: asuna, rem, yor, makima, chizuru, violet, kaguya, mai, marin, cc
#
# Note: this is separate from the fixed "neutral" persona (currently Asuna,
# see NEUTRAL_PERSONA_ID in src/constants.ts) that ALWAYS writes welcome
# messages, regardless of this setting or later /persona set changes.
DEFAULT_PERSONA=asuna

# ─── ACCESS CONTROL ───────────────────────────────────────────────────────────
# Comma-separated Discord IDs seeded as "normal" access on first run.
# Manage roles afterward with /auth in Discord (owner only).
AUTHORIZED_USERS=id1,id2,id3

# ─── BEHAVIOR ────────────────────────────────────────────────────────────────
# Respond to every message in every channel, not just @mentions/DMs/replies-to-bot.
RESPOND_TO_ALL=false

# Conversation turn-pairs to keep in memory per channel.
MAX_HISTORY=30

# Chance (0.0–1.0) the bot reacts to a message with a random app emoji.
REACTION_CHANCE=0.3

# Safety ceiling on outgoing chat-provider calls per rolling 60-second window. Once hit,
# new calls are refused outright (with a friendly message) rather than risking the
# provider's own hard rate limit. Check your provider's free-tier RPM and set this a
# couple below it — e.g. a 15 RPM tier should use 14 here. The affection meter roughly
# doubles call volume per message, so this matters more now than it used to.
CHAT_RATE_LIMIT_PER_MINUTE=14

# Default timezone for /remind when a user hasn't set their own with /remind timezone.
DEFAULT_TIMEZONE=UTC

# ─── MONITORING & LOGGING ─────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# Also write logs to data/logs/system/ (in addition to console). Console logs
# already show up in Railway's dashboard, so this is optional.
LOG_TO_FILE=false

# Port for the built-in HTTP server (Railway sets this automatically).
# Serves /health (uptime check) and /avatars/<file> (persona avatar hosting).
PORT=3000

# ─── PERSONA AVATARS (webhook identities) ────────────────────────────────────
# Discord's webhook API needs a public URL to fetch avatar images from — this
# bot serves the /avatars folder itself via the HTTP server above.
#
# On Railway: Settings → Networking → Public Networking → Generate Domain.
# Once generated, Railway auto-injects RAILWAY_PUBLIC_DOMAIN and this needs no
# further configuration.
#
# Hosting elsewhere, or want a custom domain? Set this explicitly instead
# (takes priority over RAILWAY_PUBLIC_DOMAIN):
PUBLIC_URL=

# ─── CUSTOM ERROR MESSAGES ─────────────────────────────────────────────────────
# Replace raw SDK error text with something friendlier. Per-persona overrides
# can also be set in src/personas/<id>.ts under errorMessages.
ERROR_MSG_OVERLOADED=i'm a bit overwhelmed right now, try again in a sec 😅
ERROR_MSG_RATELIMIT=slow down a little, i need a breather 🥲
ERROR_MSG_AUTH=something's wrong on my end — ping the owner 🔧
ERROR_MSG_NOTFOUND=that model doesn't exist, an admin should check the config 🤔
ERROR_MSG_FALLBACK=ran into a hiccup, try again in a moment 🔄
