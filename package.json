    "@mistralai/mistralai": "^1.3.0",
    "cohere-ai": "^7.14.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
